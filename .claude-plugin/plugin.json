{
  "name": "@cyanheads/treasury-fiscaldata-mcp-server",
  "version": "0.1.0",
  "description": "MCP server for US Treasury Fiscal Data — national debt, interest rates, exchange rates, and federal revenue/spending.",
  "author": {
    "name": "cyanheads"
  },
  "homepage": "https://github.com/cyanheads/treasury-fiscaldata-mcp-server#readme",
  "repository": "https://github.com/cyanheads/treasury-fiscaldata-mcp-server",
  "license": "Apache-2.0",
  "mcpServers": {
    "@cyanheads/treasury-fiscaldata-mcp-server": {
      "command": "npx",
      "args": ["-y", "@cyanheads/treasury-fiscaldata-mcp-server"],
      "env": {
        "MCP_TRANSPORT_TYPE": "stdio"
      }
    }
  }
}
